{
  "name": "lab6-atbp-ci-cd",
  "version": "1.0.0",
  "private": true,
  "description": "Node.js сервер с Jest, Cucumber и Playwright + Allure и GitHub Actions CI/CD",
  "scripts": {
    "start": "node server.js",
    "test:unit": "jest --config jest.config.allure.js",
    "test:api:raw": "cucumber-js --config cucumber.js",
    "test:ui:raw": "npx playwright test",
    "test:api": "node scripts/run-with-server.cjs test:api:raw",
    "test:ui": "node scripts/run-with-server.cjs test:ui:raw",
    "test:all": "npm run test:unit && npm run test:api && npm run test:ui",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.2.0",
    "@playwright/test": "^1.53.0",
    "allure-commandline": "^2.38.1",
    "allure-cucumberjs": "^3.7.1",
    "allure-jest": "^3.7.1",
    "allure-js-commons": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "jest": "^29.7.0",
    "tree-kill": "^1.2.2",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=18"
  }
}
